<div class="container">
    <text class="title">我的书架</text>

    <div class="empty-box" if="{{fileList.length === 0}}">
        <text class="empty-tip">暂无本地小说，请先导入</text>
    </div>

    <list class="book-list" else>
        <list-item class="book-item" for="{{fileList}}" onclick="openBook($item)">
            <text class="book-name">{{$item}}</text>
        </list-item>
    </list>
</div>